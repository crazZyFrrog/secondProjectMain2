# Скопируйте как .env.production перед локальной сборкой для Timeweb Hosting:
#   copy .env.timeweb.example .env.production   (Windows CMD)
#   cp .env.timeweb.example .env.production     (macOS/Linux)
#
# Замените URL на ваш бэкенд Timeweb Cloud Apps после деплоя API.

VITE_API_URL=https://YOUR-BACKEND.timeweb.cloud/api

# Кастомный домен API (если настроили api.myfirstproject.su):
# VITE_API_URL=https://api.myfirstproject.su/api
