# API Configuration
#
# Разработка (прокси Vite → backend на :5001): оставьте пустым или не задавайте
# VITE_API_URL=
#
# Проверка перед Vercel: скопируйте .env.production.example → .env.production
# и задайте URL бэкенда (см. npm run verify:prod в frontend/package.json)
#
# Продакшен на Vercel: переменная VITE_API_URL в настройках проекта Vercel
# VITE_API_URL=https://your-backend-domain.com/api

# Sentry (проект Browser/React в Sentry; только VITE_* попадает в клиентский бандл)
# VITE_SENTRY_DSN=https://...@....ingest.sentry.io/...
