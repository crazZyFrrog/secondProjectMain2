# Сборка фронта для Timeweb Хостинг (бэкенд на Amvera).
#
# Скопируйте как .env.production перед npm run build:
#   copy .env.timeweb-hosting.example .env.production   (Windows CMD / PowerShell)
#   cp .env.timeweb-hosting.example .env.production     (macOS/Linux)
#
# Полный гайд: docs/TIMEWEB_AMVERA_HYBRID.md

# Адрес API на Amvera. Обязательно с /api на конце, без слэша после api.
VITE_API_URL=https://conslanback-vladislav7599.amvera.io/api

# После сборки: npm run build → загрузить содержимое dist/ на FTP (hosting.timeweb.ru).
# На Amvera задайте FRONTEND_URL=https://myfirstproject.su,https://www.myfirstproject.su,http://localhost:5173
