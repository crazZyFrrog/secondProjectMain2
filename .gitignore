####################################
# Общие настройки Git ignore
####################################

# OS
.DS_Store
Thumbs.db

# IDE / редакторы
.vscode/
.idea/
*.code-workspace

# Логи
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

####################################
# Frontend (React / Vite)
####################################

frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.turbo/
frontend/.cache/

####################################
# Backend (FastAPI / Python)
####################################

# Виртуальные окружения
.venv/
venv/
backend/.venv/

# Кэш Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Базы данных
*.db
*.sqlite3

####################################
# Секреты и окружение
####################################

.env
.env.*
!.env.example
!frontend/.env.production.example

backend/.env

####################################
# Telegram Bot (tg_bot/)
####################################

tg_bot/node_modules/
tg_bot/.env
tg_bot/service-account.json

####################################
# Playwright тесты
####################################

# Результаты тестов
test-results/
playwright-report/
playwright/.cache/

# Видео и скриншоты из тестов (опционально, можно оставить для CI)
# test-results/**/*.png
# test-results/**/*.webm

