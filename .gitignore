####################################
# Общие настройки Git ignore
####################################

# OS
.DS_Store
Thumbs.db

# IDE / редакторы
.vscode/
.idea/
*.code-workspace

# Логи
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

####################################
# Frontend (React / Vite)
####################################

frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.turbo/
frontend/.cache/

####################################
# Backend (FastAPI / Python)
####################################

# Виртуальные окружения
.venv/
venv/
backend/.venv/

# Кэш Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Базы данных
*.db
*.sqlite3

####################################
# Секреты и окружение
####################################

.env
.env.*
!.env.example

backend/.env

