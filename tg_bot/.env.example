# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# Менеджер — chat_id куда отправлять уведомления о новых заявках
MANAGER_CHAT_ID=123456789

# OpenAI (для FAQ-сценария, опционально)
OPENAI_API_KEY=sk-...

# GigaChat (LLM-консультант по тарифам и платформе)
# Получить ключ: https://developers.sber.ru/portal/products/gigachat
# Значение — Base64-encoded строка вида ClientID:ClientSecret
GIGACHAT_API_KEY=your_gigachat_credentials_base64_here

# Google Sheets
# ID таблицы (из URL: docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit)
SPREADSHEET_ID=your_spreadsheet_id_here
# Путь к JSON-файлу сервисного аккаунта Google
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json

# SQLite — база бота (заявки, услуги, конфиг)
SQLITE_DB_PATH=./data/bot.db
