# JWT Configuration
JWT_SECRET=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=120

# Database Configuration
# For SQLite (local development):
# DATABASE_URL=
# For PostgreSQL (production):
# DATABASE_URL=postgresql://username:password@host:5432/database_name

# Telegram Bot Integration (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_MANAGER_CHAT_ID=your_chat_id_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# CORS: разрешить любой https://*.vercel.app (превью). По умолчанию выключено — включите true при необходимости.
# ALLOW_VERCEL_APP_CORS=true

# Режим приложения: production | prod — отключаются /docs, /redoc, /openapi.json
# APP_ENV=production

# Лимит запросов на POST /api/auth/login и /api/auth/register (на IP; формат slowapi)
# AUTH_RATE_LIMIT=10/minute

# Только для pytest: путь к файлу SQLite (в проде не задавать)
# SQLITE_DB_PATH=

# Sentry (Python-проект в Sentry; опционально — без DSN SDK не инициализируется)
# SENTRY_DSN=https://...@....ingest.sentry.io/...
